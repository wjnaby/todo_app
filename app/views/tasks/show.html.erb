<div class="container mt-5 d-flex justify-content-center">
  <div class="col-md-8 col-lg-6">

    <!-- Task Card -->
    <div class="card shadow-sm bg-white">
      <div class="card-body">
        <h4 class="card-title text-center mb-3 text-dark"><%= @task.title %></h4>

        <p class="card-text text-dark"><strong>Details:</strong> <%= @task.details.presence || "No details provided" %></p>

        <p class="card-text text-dark">
          <strong>Due Date:</strong>
          <% if @task.due_date.present? %>
            <%= @task.due_date.strftime("%d %b %Y") %>
          <% else %>
            <em>No due date set</em>
          <% end %>
        </p>

        <p class="card-text text-dark">
          <strong>Completed:</strong>
          <% if @task.completed %>
            <span class="badge bg-success">Yes</span>
          <% else %>
            <span class="badge bg-warning text-dark">No</span>
          <% end %>
        </p>

        <% if @task.category.present? %>
          <p class="card-text">
            <span class="badge 
              <%= case @task.category
                  when "Work" then "bg-primary"
                  when "Personal" then "bg-success"
                  when "Wishlist" then "bg-purple text-white"
                  when "Urgent" then "bg-danger"
                  when "Daily" then "bg-info text-dark"
                  else "bg-secondary"
              end %>">
              <%= @task.category %>
            </span>
          </p>
        <% end %>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex justify-content-center gap-2 mt-3">
      <!-- Edit button -->
      <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#editTaskModal">
        <i class="bi bi-pencil-square"></i> Edit
      </button>

      <!-- Back button -->
      <%= link_to tasks_path, class: "btn btn-secondary" do %>
        <i class="bi bi-arrow-left-circle"></i> Back
      <% end %>

      <!-- Destroy button (only for saved tasks) -->
      <% if @task.persisted? %>
        <%= button_to task_path(@task),
              method: :delete,
              form: { class: "d-inline" },
              class: "btn btn-danger",
              onclick: "return confirm('Are you sure you want to delete this task?');" do %>
          <i class="bi bi-trash"></i> Destroy
        <% end %>
      <% end %>
    </div>

    <!-- Edit Modal -->
    <div class="modal fade" id="editTaskModal" tabindex="-1" aria-labelledby="editTaskModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white">
          <div class="modal-header">
            <h5 class="modal-title text-dark" id="editTaskModalLabel">Edit Task</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>

          <div class="modal-body">
            <%= form_with(model: @task, local: true) do |form| %>
              <div class="mb-3">
                <%= form.label :title, "Title", class: "form-label text-dark" %>
                <%= form.text_field :title, class: "form-control" %>
              </div>

              <div class="mb-3">
                <%= form.label :details, "Details", class: "form-label text-dark" %>
                <%= form.text_area :details, class: "form-control" %>
              </div>

              <div class="mb-3">
                <%= form.label :due_date, "Due Date", class: "form-label text-dark" %>
                <%= form.date_field :due_date, class: "form-control" %>
              </div>

              <div class="mb-3">
                <%= form.label :category, "Category", class: "form-label" %>
                <%= form.select :category,
                      [["Work", "Work"], ["Personal", "Personal"], ["Wishlist", "Wishlist"], ["Daily", "Daily"], ["Urgent", "Urgent"]],
                      { include_blank: "Choose a category" },
                      class: "form-select" %>
              </div>

              <div class="form-check mb-3">
                <%= form.check_box :completed, class: "form-check-input" %>
                <%= form.label :completed, "Completed", class: "form-check-label text-dark" %>
              </div>

              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <%= form.submit "Save Changes", class: "btn btn-primary" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <% if @task.errors.any? %>
      <script>
        document.addEventListener("DOMContentLoaded", function() {
          var editModal = new bootstrap.Modal(document.getElementById('editTaskModal'));
          editModal.show();
        });
      </script>
    <% end %>

  </div>
</div>
