<div class="container my-5 d-flex justify-content-center">
  <div class="card shadow-lg bg-dark text-white w-100" style="max-width: 700px;">
    <div class="card-body">
      <h2 class="card-title text-center mb-4">📝 <%= @memo.title %></h2>

      <p class="card-text mb-4" style="white-space: pre-wrap;"><%= @memo.content %></p>

      <div class="d-flex justify-content-center gap-2">
        <%= link_to edit_memo_path(@memo), class: "btn btn-warning" do %>
          <i class="bi bi-pencil"></i> Edit
        <% end %>

        <%= link_to memos_path, class: "btn btn-secondary" do %>
          <i class="bi bi-arrow-left"></i> Back
        <% end %>

        <%= link_to memo_path(@memo),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "btn btn-danger" do %>
          <i class="bi bi-trash"></i> Delete
        <% end %>
      </div>
    </div>
  </div>
</div>
