<div class="container my-5 d-flex justify-content-center">
  <div class="card shadow-lg bg-dark text-white w-100" style="max-width: 700px;">
    <div class="card-body">
      <h2 class="card-title text-center mb-4">✏️ Edit Memo</h2>

      <%= form_with model: @memo, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :title, class: "form-label text-white" %>
          <%= f.text_field :title, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :content, class: "form-label text-white" %>
          <%= f.text_area :content, rows: 6, class: "form-control", required: true %>
        </div>

        <div class="d-flex justify-content-center gap-2">
          <%= f.submit "Update Memo", class: "btn btn-warning" %>
          <%= link_to memos_path, class: "btn btn-secondary" do %>Cancel<% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
