<h1>Edit Todo</h1>

<%= form_with(model: @todo, local: true) do |form| %>
  <div class="mb-3">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :description %>
    <%= form.text_area :description, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :due_date %>
    <%= form.date_field :due_date, class: "form-control" %>
  </div>

  <div class="mb-3 form-check">
    <%= form.check_box :completed, class: "form-check-input" %>
    <%= form.label :completed, class: "form-check-label" %>
  </div>

  <div class="actions">
    <%= form.submit "Update Todo", class: "btn btn-primary" %>
    <%= link_to "Back", todos_path, class: "btn btn-secondary" %>

    <% if current_user.admin? %>
      <%= link_to "Delete Todo", todo_path(@todo), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
    <% end %>
  </div>
<% end %>
